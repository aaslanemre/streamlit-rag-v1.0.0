      "position": [380, 520],
      "parameters": {
        "model": "llama3.2",
        "options": {
          "temperature": 0.1
        }
      },
      "credentials": {
        "ollamaApi": {
          "id": "REPLACE_WITH_CREDENTIAL_ID",
